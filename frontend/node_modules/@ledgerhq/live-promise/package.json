{
  "name": "@ledgerhq/live-promise",
  "version": "0.2.3",
  "description": "Ledger Live Promise utilities",
  "keywords": [
    "Ledger"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LedgerHQ/ledger-live.git"
  },
  "bugs": {
    "url": "https://github.com/LedgerHQ/ledger-live/issues"
  },
  "homepage": "https://github.com/LedgerHQ/ledger-live/tree/develop/libs/promise",
  "publishConfig": {
    "access": "public"
  },
  "main": "lib/index.js",
  "module": "lib-es/index.js",
  "types": "lib/index.d.ts",
  "license": "Apache-2.0",
  "dependencies": {
    "@ledgerhq/logs": "^6.17.0"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "jest": "30.2.0",
    "@swc/jest": "0.2.39",
    "@swc/core": "1.15.11"
  },
  "exports": {
    ".": {
      "@ledgerhq/source": "./src/index.ts",
      "import": "./lib-es/index.js",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./lib-es/*": "./lib-es/*.js",
    "./lib/*": "./lib/*.js",
    "./*": {
      "@ledgerhq/source": "./src/*.ts",
      "import": "./lib-es/*.js",
      "require": "./lib/*.js",
      "default": "./lib/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf lib lib-es",
    "build": "tsc --project tsconfig.build.json && tsc --project tsconfig.build.json -m esnext --moduleResolution bundler --outDir lib-es",
    "prewatch": "pnpm build",
    "watch": "tsc --watch --project tsconfig.build.json",
    "watch:es": "tsc --watch --project tsconfig.build.json -m esnext --moduleResolution bundler --outDir lib-es",
    "lint": "eslint ./src --no-error-on-unmatched-pattern --ext .ts,.tsx --cache",
    "lint:fix": "pnpm lint --fix",
    "test": "jest",
    "coverage": "jest --coverage",
    "unimported": "pnpm knip --directory ../.. -W libs/promise"
  }
}