{
  "name": "@mysten/ledgerjs-hw-app-sui",
  "version": "0.8.0",
  "description": "Ledger Hardware Wallet Sui Application API",
  "keywords": [
    "Ledger",
    "LedgerWallet",
    "LedgerSigner",
    "Sui",
    "NanoS",
    "Blue",
    "Hardware Wallet"
  ],
  "author": "Mysten Labs <build@mystenlabs.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MystenLabs/ts-sdks.git"
  },
  "bugs": {
    "url": "https://github.com/MystenLabs/ts-sdks/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/MystenLabs/ts-sdks/tree/main/packages/ledgerjs-hw-app-sui#readme",
  "files": [
    "CHANGELOG.md",
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/Sui.mjs",
  "types": "./dist/Sui.d.mts",
  "exports": {
    ".": {
      "types": "./dist/Sui.d.mts",
      "import": "./dist/Sui.mjs",
      "default": "./dist/Sui.mjs"
    }
  },
  "dependencies": {
    "@ledgerhq/devices": "^8.9.0",
    "@ledgerhq/errors": "^6.28.0",
    "@ledgerhq/hw-bolos": "^6.32.12",
    "@ledgerhq/hw-transport": "^6.31.16",
    "@ledgerhq/ledger-cal-service": "^1.10.0",
    "fast-sha256": "^1.3.0",
    "semver": ">=7.5.2"
  },
  "devDependencies": {
    "@ledgerhq/hw-transport-mocker": "^6.30.1",
    "@types/node": "^25.0.8",
    "@types/semver": "^7.7.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "scripts": {
    "clean": "rm -rf tsconfig.tsbuildinfo ./dist",
    "build": "rm -rf dist && tsc --noEmit && tsdown",
    "oxlint:check": "oxlint  .",
    "oxlint:fix": "oxlint --fix",
    "lint": "pnpm run oxlint:check && pnpm run prettier:check",
    "lint:fix": "pnpm run oxlint:fix && pnpm run prettier:fix",
    "prettier:check": "prettier -c --ignore-unknown .",
    "prettier:fix": "prettier -w --ignore-unknown .",
    "prettier:fix:watch": "onchange '**' -i -f add -f change -j 5 -- prettier -w --ignore-unknown {{file}}",
    "test": "pnpm test:typecheck && pnpm test:unit",
    "test:typecheck": "tsc -p ./tests",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  }
}